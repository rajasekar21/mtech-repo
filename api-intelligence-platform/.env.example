# ── Database ──────────────────────────────────────────────────────────
POSTGRES_PASSWORD=api_secret_change_me
NEO4J_PASSWORD=neo4j_secret_change_me

# ── Security ──────────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_long_random_string_in_production

# ── AI Backend (ollama = open-source default, openai = cloud) ─────────
AI_BACKEND=ollama

# Ollama (default — self-hosted, open-source)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# OpenAI (optional — cloud, requires API key)
# AI_BACKEND=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Monitoring ────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
